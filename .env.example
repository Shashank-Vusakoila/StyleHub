# ─────────────────────────────────────────────────────────
#  LUXE FINDS — Environment Variables
#  Copy this file to .env.local and fill in your values.
#  NEVER commit .env.local to GitHub.
# ─────────────────────────────────────────────────────────

# ── Firebase (Database + Auth only — no Storage needed) ──
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ── Cloudinary (FREE image hosting — replaces Firebase Storage) ──
# Sign up free at cloudinary.com — no credit card needed
# Free tier: 25GB storage + 25GB bandwidth/month
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset_name

# ── Site ──────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://yourdomain.vercel.app
NEXT_PUBLIC_SITE_NAME=Luxe Finds

# ── Amazon ────────────────────────────────────────────────
# Your Amazon Associates tag — goes at end of every affiliate link
# e.g.  amazon.in/dp/B09XYZ?tag=luxefinds-21
NEXT_PUBLIC_AMAZON_TAG=storehub0a68-21

# ─────────────────────────────────────────────────────────
# NOTE: NEXT_PUBLIC_ prefix = safe to use in browser code
# Never put API secrets in NEXT_PUBLIC_ variables
# ─────────────────────────────────────────────────────────
